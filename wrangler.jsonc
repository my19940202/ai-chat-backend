{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ai-chat-backend",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-04-22",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "routes": [],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "ai-chat",
      "database_id": "454c26cb-07cc-47b0-82ec-daf3549f4f9b"
    }
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "ai-chat-backend"
    }
  ],
  "r2_buckets": [
    {
      "binding": "R2_BUCKET",
      "bucket_name": "ai-chat-uploads",
      "remote": true
    }
  ],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": false,
      "persist": true,
      "head_sampling_rate": 1
    }
  },
  "ai": {
    "binding": "AI",
    "remote": true
  },
  "vars": {
    "AI_GATEWAY_ID": "ai-chat",
    "AI_GATEWAY_ACCOUNT_ID": "",
    "OPENAI_API_KEY": "",
    "NEXT_PUBLIC_APP_NAME": "AI Chat"
  }
}
